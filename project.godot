; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[addons]

curved_lines_2d/add_collision_enabled=false
curved_lines_2d/add_stroke_enabled=true
curved_lines_2d/add_fill_enabled=true
curved_lines_2d/stroke_color=Color(0, 0, 0, 1)
curved_lines_2d/stroke_width=5.0
curved_lines_2d/line_joint_mode=2
curved_lines_2d/line_end_cap=2
curved_lines_2d/line_begin_cap=2
curved_lines_2d/paint_order=0
curved_lines_2d/show_point_numbers=true
curved_lines_2d/hints_enabled=true
curved_lines_2d/snap_to_pixel=false
curved_lines_2d/snap_resolution=1.0
curved_lines_2d/editing_enabled=true
curved_lines_2d/fill_color=Color(0.556863, 0.713726, 0.423529, 0.533333)
curved_lines_2d/add_collision_type=0
curved_lines_2d/use_line_2d_for_stroke=true
curved_lines_2d/update_curve_at_runtime=true
curved_lines_2d/make_resources_local_to_scene=true
curved_lines_2d/default_tolerance_degrees=4.0
curved_lines_2d/default_max_stages=5
curved_lines_2d/antialiased_line_2d=false
curved_lines_2d/granularity=1.0
curved_lines_2d/keep_drawing=0
curved_lines_2d/close_pencil_path=false
curved_lines_2d/brush_shape=0
curved_lines_2d/brush_size_x=8.0
curved_lines_2d/brush_size_y=8.0
curved_lines_2d/brush_rotation=238.0

[application]

config/name="EZ Curved Lines 2D"
run/main_scene="uid://gmlmhdf0cxl8"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="uid://b5yxa1e62b0hb"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1080

[editor_plugins]

enabled=PackedStringArray("res://addons/curved_lines_2d/plugin.cfg", "res://addons/godot-plugin-refresher/plugin.cfg")

[rendering]

anti_aliasing/quality/msaa_2d=3
anti_aliasing/screen_space_roughness_limiter/amount=4.0
anti_aliasing/screen_space_roughness_limiter/limit=1.0
environment/defaults/default_clear_color=Color(0.211765, 0.239216, 0.290196, 1)
anti_aliasing/quality/screen_space_aa=1
